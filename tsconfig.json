{
  "compilerOptions": {
    "outDir": "./libs",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": [
      "esnext",
      "es2017",
      "es2018",
      "es2019",
      "es2020",
      "es2021",
      "es2022",
      "es2023",
      "DOM",
      "DOM.Iterable",
    ],
    "noErrorTruncation": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "inlineSources": true,
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    //"useDefineForClassFields": true,
    "types": [
      "@types/mocha",
      "@types/chrome",
      "@types/node"
    ]
  },
  "include": [
    "./**/*.ts",
    "./*.ts"
  ]
}
